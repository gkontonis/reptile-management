# TrueNAS / Production Environment Configuration
# Copy this file to .env.truenas and fill in your values.
# NEVER commit .env.truenas to version control.

# Database Configuration
POSTGRES_DB=reptilemanagement
POSTGRES_USER=postgres
POSTGRES_PASSWORD=<your-secure-password>

# Frontend Configuration - port exposed to your network
FRONTEND_PORT=9999

# JWT Configuration
# Generate a secure random key with:
#   openssl rand -base64 32
JWT_SECRET=<output-of-openssl-rand-base64-32>
JWT_EXPIRATION=86400000
